#include <physical_layouts.dtsi>

/ {
    pacane_physical_layout: pacane_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        keys = <
            // Row 0 (left)
            &key_physical_attrs 100   0   100 100 0 0 0
            &key_physical_attrs 100 100   100 100 0 0 0
            &key_physical_attrs 100 200   100 100 0 0 0
            &key_physical_attrs 100 300   100 100 0 0 0
            &key_physical_attrs 100 400   100 100 0 0 0
            &key_physical_attrs 100 500   100 100 0 0 0
            // Row 0 (right)
            &key_physical_attrs 100 700   100 100 0 0 0
            &key_physical_attrs 100 800   100 100 0 0 0
            &key_physical_attrs 100 900   100 100 0 0 0
            &key_physical_attrs 100 1000  100 100 0 0 0
            &key_physical_attrs 100 1100  100 100 0 0 0
            &key_physical_attrs 100 1200  100 100 0 0 0
            // Row 1 (left)
            &key_physical_attrs 100   0   200 100 0 0 0
            &key_physical_attrs 100 100   200 100 0 0 0
            &key_physical_attrs 100 200   200 100 0 0 0
            &key_physical_attrs 100 300   200 100 0 0 0
            &key_physical_attrs 100 400   200 100 0 0 0
            &key_physical_attrs 100 500   200 100 0 0 0
            // Row 1 (right)
            &key_physical_attrs 100 700   200 100 0 0 0
            &key_physical_attrs 100 800   200 100 0 0 0
            &key_physical_attrs 100 900   200 100 0 0 0
            &key_physical_attrs 100 1000  200 100 0 0 0
            &key_physical_attrs 100 1100  200 100 0 0 0
            &key_physical_attrs 100 1200  200 100 0 0 0
            // Row 2 (left)
            &key_physical_attrs 100   0   300 100 0 0 0
            &key_physical_attrs 100 100   300 100 0 0 0
            &key_physical_attrs 100 200   300 100 0 0 0
            &key_physical_attrs 100 300   300 100 0 0 0
            &key_physical_attrs 100 400   300 100 0 0 0
            &key_physical_attrs 100 500   300 100 0 0 0
            // Row 2 (right)
            &key_physical_attrs 100 700   300 100 0 0 0
            &key_physical_attrs 100 800   300 100 0 0 0
            &key_physical_attrs 100 900   300 100 0 0 0
            &key_physical_attrs 100 1000  300 100 0 0 0
            &key_physical_attrs 100 1100  300 100 0 0 0
            &key_physical_attrs 100 1200  300 100 0 0 0
            // Row 3 (left)
            &key_physical_attrs 100   0   400 100 0 0 0
            &key_physical_attrs 100 100   400 100 0 0 0
            &key_physical_attrs 100 200   400 100 0 0 0
            &key_physical_attrs 100 300   400 100 0 0 0
            &key_physical_attrs 100 400   400 100 0 0 0
            &key_physical_attrs 100 500   400 100 0 0 0
            // Row 3 (right)
            &key_physical_attrs 100 700   400 100 0 0 0
            &key_physical_attrs 100 800   400 100 0 0 0
            &key_physical_attrs 100 900   400 100 0 0 0
            &key_physical_attrs 100 1000  400 100 0 0 0
            &key_physical_attrs 100 1100  400 100 0 0 0
            &key_physical_attrs 100 1200  400 100 0 0 0
            // Row 4 - thumb row (left, starts at col 1)
            &key_physical_attrs 100 100   500 100 0 0 0
            &key_physical_attrs 100 200   500 100 0 0 0
            &key_physical_attrs 100 300   500 100 0 0 0
            &key_physical_attrs 100 400   500 100 0 0 0
            &key_physical_attrs 100 500   500 100 0 0 0
            // Row 4 - thumb row (right, ends at col 10)
            &key_physical_attrs 100 700   500 100 0 0 0
            &key_physical_attrs 100 800   500 100 0 0 0
            &key_physical_attrs 100 900   500 100 0 0 0
            &key_physical_attrs 100 1000  500 100 0 0 0
            &key_physical_attrs 100 1100  500 100 0 0 0
        >;
    };
};
